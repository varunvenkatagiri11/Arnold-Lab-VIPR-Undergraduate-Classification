{
    "study_name": "resnet152_gradual_unfreeze_sweep",
    "base_config_path": "configs/resnet152_dynamic_unfreeze.json",
    "n_trials": 30,
    "timeout_hours": 18,
    "pruning": {
        "enabled": false,
        "n_startup_trials": 5,
        "n_warmup_steps": 15,
        "interval_steps": 2
    },
    "cleanup": {
        "keep_top_n": 5,
        "cleanup_frequency": 10
    },
    "search_space": {
        "training.dynamic_unfreeze.lr_decay_ratio": {
            "type": "log_float",
            "low": 0.01,
            "high": 0.5
        },
        "training.dynamic_unfreeze.unfreeze_patience": {
            "type": "int",
            "low": 3,
            "high": 20
        }
    }
}
