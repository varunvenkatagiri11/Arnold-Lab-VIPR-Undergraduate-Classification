{
  "study_name": "vgg19_frozen_sweep",
  "base_config_path": "configs/vgg19.json",
  "n_trials": 25,
  "timeout_hours": 12,
  "pruning": {
    "enabled": false
  },
  "cleanup": {
    "keep_top_n": 5,
    "cleanup_frequency": 5
  },
  "search_space": {
    "training.learning_rate": {
      "type": "log_float",
      "low": 0.0001,
      "high": 0.01
    },
    "training.weight_decay": {
      "type": "log_float",
      "low": 1e-05,
      "high": 0.01
    },
    "augmentations.color_jitter": {
      "type": "float",
      "low": 0.0,
      "high": 0.15
    },
    "augmentations.random_rotation": {
      "type": "float",
      "low": 0.0,
      "high": 30.0
    },
    "model.classifier_hidden": {
      "type": "categorical",
      "choices": [
        [
          512
        ],
        [
          1024
        ],
        [
          2048
        ],
        [
          1024,
          512
        ],
        [
          2048,
          1024
        ]
      ]
    },
    "model.dropout": {
      "type": "float",
      "low": 0.1,
      "high": 0.5
    }
  }
}